# Production environment — copy to .env on your server or VPS
# Replace example.com with your real domain

# ── Domain (required for VPS full deploy) ──────────────────────────────────
SITE_DOMAIN=example.com
ACME_EMAIL=you@example.com

# Public URLs (used by frontend + CORS)
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_API_URL=https://api.example.com
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ── Security (generate a new random 64-char hex string for production) ───
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── MongoDB (optional — leave unset to use bundled MongoDB container) ──────
# For MongoDB Atlas, set base URI without db name; compose appends /auth_db etc.
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net

# ── Cloudinary (required for portfolio media uploads) ──────────────────────
CLOUDINARY_URL=cloudinary://<969582483233315>:<gOmw9l59tn3-Afjkaaol9D-VTJs>@dtq0jtehm
CLOUDINARY_API_KEY=969582483233315
CLOUDINARY_API_SECRET=gOmw9l59tn3-Afjkaaol9D-VTJs

# ── Email (optional) ───────────────────────────────────────────────────────
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
